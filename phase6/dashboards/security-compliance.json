{
  "uid": "security-compliance",
  "title": "Security & Compliance",
  "description": "Zero trust posture, Falco events, Vault health, OPA violations, supply chain status. SOC 2 evidence in one pane.",
  "tags": ["security", "compliance", "soc2", "zerotrust"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Security Posture",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "description": "Overall security posture score (100 = no active incidents)",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [{
        "expr": "100 - (count(falco_events_total{priority='Critical'} > 0) * 20)",
        "legendFormat": "Posture Score"
      }]
    },

    {
      "id": 2,
      "title": "Vault Status",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UNSEALED ✅", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "SEALED 🚨", "color": "red" } } }
          ]
        }
      },
      "targets": [{
        "expr": "vault_core_unsealed",
        "legendFormat": "Vault"
      }]
    },

    {
      "id": 3,
      "title": "OPA Policy Violations (24h)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [{
        "expr": "sum(increase(gatekeeper_violations_total[24h]))",
        "legendFormat": "Violations"
      }]
    },

    {
      "id": 4,
      "title": "mTLS Coverage",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "description": "% of service-to-service traffic using mTLS",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(istio_requests_total{connection_security_policy='mutual_tls'}) / sum(istio_requests_total)",
        "legendFormat": "mTLS Coverage"
      }]
    },

    {
      "id": 5,
      "title": "Signed Images in Production",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "1 - (policy_controller_admission_webhook_request_total{admitted='false'} / policy_controller_admission_webhook_request_total)",
        "legendFormat": "Signed %"
      }]
    },

    {
      "id": 6,
      "title": "Falco Security Events (24h)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "description": "Runtime security events by priority. Critical events trigger automated isolation.",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Warning" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum by (priority) (increase(falco_events_total[1h]))",
          "legendFormat": "{{ priority }}"
        }
      ]
    },

    {
      "id": 7,
      "title": "Falco Events by Rule (24h)",
      "type": "table",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 7 },
      "description": "Which rules are firing most. High counts of the same rule = tuning needed.",
      "targets": [{
        "expr": "sort_desc(sum by (rule) (increase(falco_events_total[24h])))",
        "legendFormat": "{{ rule }}",
        "instant": true
      }]
    },

    {
      "id": 8,
      "title": "Vault Secret Lease Activity",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 6 },
      "description": "Secret reads and rotations. Flat line = something stopped rotating (investigate).",
      "targets": [
        {
          "expr": "rate(vault_audit_log_request_total[5m])",
          "legendFormat": "Secret requests/s"
        },
        {
          "expr": "rate(vault_database_secret_renewals_total[5m])",
          "legendFormat": "DB credential rotations/s"
        }
      ]
    },

    {
      "id": 9,
      "title": "SOC 2 Compliance Checklist",
      "type": "table",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 6 },
      "description": "Live compliance state. Green = passing. Red = evidence gap.",
      "targets": [
        { "expr": "min(vault_core_unsealed)", "legendFormat": "CC6.1 — Vault unsealed (dynamic secrets active)" },
        { "expr": "(sum(istio_requests_total{connection_security_policy='mutual_tls'}) / sum(istio_requests_total)) > 0.99", "legendFormat": "CC6.7 — mTLS > 99%" },
        { "expr": "gatekeeper_violations_total == 0", "legendFormat": "CC8.1 — No OPA violations" },
        { "expr": "falco_events_total{priority='Critical'} == 0", "legendFormat": "CC9.2 — No critical Falco events" }
      ]
    }

  ]
}
