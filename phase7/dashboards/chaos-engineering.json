{
  "uid": "chaos-engineering",
  "title": "Chaos Engineering — Game Day",
  "description": "Real-time blast radius, recovery metrics, and experiment history. Open this during every Game Day.",
  "tags": ["chaos", "gameday", "resilience"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "annotations": {
    "list": [
      {
        "name": "Chaos Events",
        "datasource": "Prometheus",
        "enable": true,
        "expr": "changes(chaos_mesh_experiment_active_total[1m]) > 0",
        "step": "60s",
        "titleFormat": "Chaos: {{ experiment }}",
        "iconColor": "red"
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "title": "🔴 ACTIVE CHAOS EXPERIMENTS",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [{
        "expr": "count(chaos_mesh_experiment_active_total > 0) or vector(0)",
        "legendFormat": "Active Experiments"
      }]
    },

    {
      "id": 2,
      "title": "Error Rate (Real-time)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 10, "h": 4 },
      "description": "Watch this during chaos. Should stay below 0.1% (SLO threshold).",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 },
              { "color": "red", "value": 0.005 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line+area" } }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(order_service_requests_total{status_code=~'5..'}[1m])) / sum(rate(order_service_requests_total[1m]))",
          "legendFormat": "Order Service Error Rate"
        },
        {
          "expr": "sum(rate(payment_service_requests_total{status_code=~'5..'}[1m])) / sum(rate(payment_service_requests_total[1m]))",
          "legendFormat": "Payment Service Error Rate"
        }
      ]
    },

    {
      "id": 3,
      "title": "Error Budget Remaining",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "description": "If this hits < 20% during chaos — abort the experiment.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "min(slo:order_service_availability:error_budget_remaining, slo:payment_service_availability:error_budget_remaining)",
        "legendFormat": "Budget Remaining"
      }]
    },

    {
      "id": 4,
      "title": "Pod Status During Chaos",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "description": "Watch pods go down and come back up. Recovery speed = health of scheduling.",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum by (phase) (kube_pod_status_phase{namespace='app'})",
          "legendFormat": "{{ phase }}"
        }
      ]
    },

    {
      "id": 5,
      "title": "Request Latency During Chaos (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "description": "Latency spike = pods are overloaded during rescheduling. HPA should kick in.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(order_service_request_duration_seconds_bucket[1m])))",
          "legendFormat": "order-service p95"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(payment_service_request_duration_seconds_bucket[1m])))",
          "legendFormat": "payment-service p95"
        }
      ]
    },

    {
      "id": 6,
      "title": "Auto-Remediation Workflows Triggered",
      "type": "stat",
      "gridPos": { "x": 0, "y": 10, "w": 6, "h": 4 },
      "description": "Should be non-zero during experiments. Self-healing is working.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [{
        "expr": "sum(increase(argo_workflows_count{phase='Succeeded',namespace='argo'}[1h]))",
        "legendFormat": "Workflows Succeeded"
      }]
    },

    {
      "id": 7,
      "title": "Replica Count — Real vs Desired",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 10, "w": 10, "h": 4 },
      "description": "HPA scaling during chaos. Desired should never be > Available for long.",
      "targets": [
        {
          "expr": "kube_deployment_spec_replicas{namespace='app'}",
          "legendFormat": "{{ deployment }} (desired)"
        },
        {
          "expr": "kube_deployment_status_replicas_available{namespace='app'}",
          "legendFormat": "{{ deployment }} (available)"
        }
      ]
    },

    {
      "id": 8,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "max by (consumergroup) (kafka_consumergroup_lag)",
        "legendFormat": "{{ consumergroup }}"
      }]
    },

    {
      "id": 9,
      "title": "ML Anomaly Detector — Ensemble Confidence",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 5 },
      "description": "Does the anomaly detector catch the injected failure? Should spike when chaos is active.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.75 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "targets": [{
        "expr": "ml_ensemble_confidence",
        "legendFormat": "{{ service }}: {{ metric }}"
      }]
    },

    {
      "id": 10,
      "title": "Experiment History",
      "type": "table",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 5 },
      "description": "All chaos experiments run in the last 30 days with their outcomes.",
      "targets": [{
        "expr": "chaos_mesh_experiment_active_total",
        "legendFormat": "{{ kind }}: {{ name }}",
        "instant": true
      }]
    }

  ]
}
