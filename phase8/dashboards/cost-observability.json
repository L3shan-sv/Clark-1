{
  "uid": "cost-observability",
  "title": "💰 Cost Observability",
  "description": "Real-time cluster spend, cost per request, namespace breakdown, waste detection, rightsizing recommendations, and 30-day forecast. Built on OpenCost + Prometheus.",
  "tags": ["cost", "finops", "opencost", "rightsizing"],
  "timezone": "browser",
  "refresh": "60s",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Estimated Monthly Bill",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 5, "h": 4 },
      "description": "Current hourly rate × 730 hours. Does not include data transfer or support.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "yellow", "value": 12000 },
              { "color": "red",    "value": 15000 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "cost:cluster_total_per_hour:dollars * 730",
        "legendFormat": "Monthly Estimate"
      }]
    },

    {
      "id": 2,
      "title": "30-Day Cost Forecast",
      "type": "stat",
      "gridPos": { "x": 5, "y": 0, "w": 5, "h": 4 },
      "description": "Linear extrapolation of current trend. Red if forecast exceeds $15k budget.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "yellow", "value": 12000 },
              { "color": "red",    "value": 15000 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "cost:cluster_forecast_30d:dollars",
        "legendFormat": "30-Day Forecast"
      }]
    },

    {
      "id": 3,
      "title": "Potential Monthly Savings",
      "type": "stat",
      "gridPos": { "x": 10, "y": 0, "w": 5, "h": 4 },
      "description": "Rightsizing engine estimate. Apply the patch to capture this.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "targets": [{
        "expr": "sum(rightsizing_estimated_monthly_savings_dollars)",
        "legendFormat": "Savings Available"
      }]
    },

    {
      "id": 4,
      "title": "CPU Efficiency",
      "type": "gauge",
      "gridPos": { "x": 15, "y": 0, "w": 4, "h": 4 },
      "description": "Actual CPU usage / requested CPU. < 40% = heavily overprovisioned.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.4  },
              { "color": "green",  "value": 0.7  }
            ]
          }
        }
      },
      "targets": [{
        "expr": "cost:cpu_efficiency_ratio",
        "legendFormat": "CPU Efficiency"
      }]
    },

    {
      "id": 5,
      "title": "Memory Efficiency",
      "type": "gauge",
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.35 },
              { "color": "green",  "value": 0.65 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "cost:memory_efficiency_ratio",
        "legendFormat": "Memory Efficiency"
      }]
    },

    {
      "id": 6,
      "title": "Hourly Spend Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 14, "h": 7 },
      "description": "Hourly cluster cost. Spikes = HPA scale-out events. Patterns = business hours. Anomalies = investigate.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "cost:cluster_total_per_hour:dollars",
          "legendFormat": "Total"
        },
        {
          "expr": "cost:namespace_per_hour:dollars{namespace='app'}",
          "legendFormat": "app namespace"
        },
        {
          "expr": "cost:namespace_per_hour:dollars{namespace='ml'}",
          "legendFormat": "ml namespace"
        },
        {
          "expr": "cost:namespace_per_hour:dollars{namespace='observability'}",
          "legendFormat": "observability namespace"
        }
      ]
    },

    {
      "id": 7,
      "title": "Spend by Namespace (7d)",
      "type": "piechart",
      "gridPos": { "x": 14, "y": 4, "w": 10, "h": 7 },
      "description": "Which namespace owns what % of the bill. Surprises here = team conversations.",
      "targets": [{
        "expr": "sum by (namespace) (increase(container_cost_per_hour_dollars[7d]))",
        "legendFormat": "{{ namespace }}"
      }]
    },

    {
      "id": 8,
      "title": "Cost per 1,000 Requests",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 6 },
      "description": "The unit economics metric. Rising line = getting more expensive to serve. Falling line = efficiency improving. Spike = traffic dropped while costs held.",
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "cost:order_service_per_1k_requests:dollars",
          "legendFormat": "order-service ($/1k req)"
        },
        {
          "expr": "cost:payment_service_per_1k_requests:dollars",
          "legendFormat": "payment-service ($/1k req)"
        }
      ]
    },

    {
      "id": 9,
      "title": "Waste: Unused CPU Cores by Pod",
      "type": "table",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 6 },
      "description": "Provisioned minus actual. Sorted by waste. Top rows = highest rightsizing opportunity.",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Wasted Cores" },
            "properties": [
              { "id": "unit", "value": "none" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green",  "value": null },
                  { "color": "yellow", "value": 0.5  },
                  { "color": "red",    "value": 1.0  }
                ]
              }}
            ]
          }
        ]
      },
      "targets": [{
        "expr": "sort_desc(cost:cpu_waste:cores > 0.1)",
        "legendFormat": "{{ pod }}",
        "instant": true,
        "format": "table"
      }]
    },

    {
      "id": 10,
      "title": "Rightsizing Recommendations",
      "type": "table",
      "gridPos": { "x": 0, "y": 17, "w": 14, "h": 6 },
      "description": "Auto-generated rightsizing recommendations. Green = reduce (saves money). Red = increase (prevents OOM).",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Monthly Savings" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "green", "value": 1    }
                ]
              }}
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "rightsizing_estimated_monthly_savings_dollars > 0",
          "legendFormat": "{{ namespace }}/{{ deployment }}",
          "instant": true,
          "format": "table"
        }
      ]
    },

    {
      "id": 11,
      "title": "CPU Efficiency per Deployment",
      "type": "bargauge",
      "gridPos": { "x": 14, "y": 17, "w": 10, "h": 6 },
      "description": "Actual CPU / requested CPU per deployment. Grey bar = waste. Target: > 60%.",
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.4  },
              { "color": "green",  "value": 0.65 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "rightsizing_cpu_efficiency_ratio",
        "legendFormat": "{{ namespace }}/{{ deployment }}"
      }]
    },

    {
      "id": 12,
      "title": "Memory Efficiency per Deployment",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 5 },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.35 },
              { "color": "green",  "value": 0.60 }
            ]
          }
        }
      },
      "targets": [{
        "expr": "rightsizing_memory_efficiency_ratio",
        "legendFormat": "{{ namespace }}/{{ deployment }}"
      }]
    },

    {
      "id": 13,
      "title": "Cost by Team (7d)",
      "type": "table",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 5 },
      "description": "Spend attributed to team labels on pods. Shows who's spending what.",
      "targets": [{
        "expr": "cost:team_per_day:dollars",
        "legendFormat": "{{ label_team }}",
        "instant": true,
        "format": "table"
      }]
    }

  ]
}
