{
  "uid": "global-command-center",
  "title": "🌍 Global Command Center",
  "description": "Multi-region health, cell status, traffic distribution, SLO burn rates, capacity headroom, toil budget. The single pane of glass.",
  "tags": ["global", "multi-region", "executive", "faang"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Global Health",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "description": "Overall system health across all regions and cells",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "range", "options": { "from": 0.99, "to": 1.01, "result": { "text": "HEALTHY", "color": "green" } } },
            { "type": "range", "options": { "from": 0.95, "to": 0.99, "result": { "text": "DEGRADED", "color": "yellow" } } },
            { "type": "range", "options": { "from": 0, "to": 0.95,   "result": { "text": "OUTAGE",   "color": "red" } } }
          ]
        }
      },
      "targets": [{
        "expr": "min(slo:order_service_availability:error_budget_remaining, slo:payment_service_availability:error_budget_remaining)",
        "legendFormat": "Health"
      }]
    },

    {
      "id": 2,
      "title": "Traffic by Region",
      "type": "piechart",
      "gridPos": { "x": 4, "y": 0, "w": 8, "h": 4 },
      "description": "Traffic distribution across us-east-1 (40%), us-west-2 (40%), eu-west-1 (20%)",
      "targets": [{
        "expr": "sum by (region) (rate(order_service_requests_total[1m]))",
        "legendFormat": "{{ region }}"
      }]
    },

    {
      "id": 3,
      "title": "Global RPS",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [{
        "expr": "sum(rate(order_service_requests_total[1m]))",
        "legendFormat": "Global RPS"
      }]
    },

    {
      "id": 4,
      "title": "SLO Budget Remaining",
      "type": "bargauge",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null  },
              { "color": "yellow", "value": 0.2   },
              { "color": "green",  "value": 0.5   }
            ]
          }
        }
      },
      "targets": [
        { "expr": "slo:order_service_availability:error_budget_remaining",   "legendFormat": "order-service" },
        { "expr": "slo:payment_service_availability:error_budget_remaining",  "legendFormat": "payment-service" }
      ]
    },

    {
      "id": 5,
      "title": "Regional Error Rates",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "description": "Error rate per region. Diverging lines = regional fault. Parallel lines = global issue.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null   },
              { "color": "yellow", "value": 0.001  },
              { "color": "red",    "value": 0.005  }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "targets": [{
        "expr": "sum by (region) (rate(order_service_requests_total{status_code=~'5..'}[1m])) / sum by (region) (rate(order_service_requests_total[1m]))",
        "legendFormat": "{{ region }}"
      }]
    },

    {
      "id": 6,
      "title": "Cell Health Matrix",
      "type": "table",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "description": "Error rate per cell per region. Red cell = evacuate and drain.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "yellow", "value": 0.001 },
              { "color": "red",    "value": 0.01  }
            ]
          },
          "custom": { "displayMode": "color-background" }
        }
      },
      "targets": [{
        "expr": "cell:error_rate:ratio",
        "legendFormat": "{{ region }} / {{ cell }}",
        "instant": true
      }]
    },

    {
      "id": 7,
      "title": "Request Latency — Global p95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.2  },
              { "color": "red",    "value": 0.5  }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, region) (rate(order_service_request_duration_seconds_bucket[1m])))",
        "legendFormat": "{{ region }} p95"
      }]
    },

    {
      "id": 8,
      "title": "Toil Budget (Weekly)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 10, "w": 6, "h": 5 },
      "description": "% of SRE toil budget consumed this week. Google SRE: must stay < 50%.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70   },
              { "color": "red",    "value": 100  }
            ]
          }
        }
      },
      "targets": [{
        "expr": "toil_budget_consumed_percent",
        "legendFormat": "Toil Budget Used"
      }]
    },

    {
      "id": 9,
      "title": "Automation Rate",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 10, "w": 6, "h": 5 },
      "description": "% of incidents auto-remediated. Target: > 80%. Below 50% = toil problem.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 50   },
              { "color": "green",  "value": 80   }
            ]
          }
        }
      },
      "targets": [{
        "expr": "automation_rate_percent",
        "legendFormat": "Automation Rate"
      }]
    },

    {
      "id": 10,
      "title": "Capacity Headroom by Region",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 4 },
      "description": "CPU/Memory headroom per region. < 20% = capacity planning needed.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 20   },
              { "color": "green",  "value": 40   }
            ]
          }
        }
      },
      "targets": [{
        "expr": "capacity_headroom_percent",
        "legendFormat": "{{ region }} {{ resource }}"
      }]
    },

    {
      "id": 11,
      "title": "ML Model Health",
      "type": "table",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 4 },
      "description": "Drift status and MAPE for all ML models. Red = retrain needed.",
      "targets": [
        { "expr": "ml_drift_psi_score > 0",          "legendFormat": "PSI: {{ model }}", "instant": true },
        { "expr": "ml_forecast_mape_percent",          "legendFormat": "MAPE: {{ service }}", "instant": true }
      ]
    },

    {
      "id": 12,
      "title": "Active Chaos Experiments",
      "type": "stat",
      "gridPos": { "x": 0, "y": 19, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1    }
            ]
          }
        }
      },
      "targets": [{
        "expr": "count(chaos_mesh_experiment_active_total > 0) or vector(0)",
        "legendFormat": "Active Experiments"
      }]
    },

    {
      "id": 13,
      "title": "Security Events (24h)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 19, "w": 4, "h": 3 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1    }
            ]
          }
        }
      },
      "targets": [{
        "expr": "sum(increase(falco_events_total{priority='Critical'}[24h]))",
        "legendFormat": "Critical Events"
      }]
    },

    {
      "id": 14,
      "title": "Cost Efficiency",
      "type": "stat",
      "gridPos": { "x": 8, "y": 19, "w": 4, "h": 3 },
      "description": "CPU utilisation efficiency. 1.0 = perfect. < 0.4 = overprovisioned.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green",  "value": 0.5  }
            ]
          }
        }
      },
      "targets": [{
        "expr": "cost:cpu_efficiency_ratio",
        "legendFormat": "CPU Efficiency"
      }]
    },

    {
      "id": 15,
      "title": "Estimated Monthly Cost",
      "type": "stat",
      "gridPos": { "x": 12, "y": 19, "w": 4, "h": 3 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [{
        "expr": "cost:cluster_total_per_hour:dollars * 730",
        "legendFormat": "Monthly Estimate"
      }]
    },

    {
      "id": 16,
      "title": "RL Agent Mode",
      "type": "stat",
      "gridPos": { "x": 16, "y": 19, "w": 8, "h": 3 },
      "description": "SHADOW = recommends only. AUTO = executes remediations.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "🤖 AUTO MODE", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "👁 SHADOW MODE", "color": "yellow" } } }
          ]
        }
      },
      "targets": [{
        "expr": "1",
        "legendFormat": "RL Agent"
      }]
    }

  ]
}
